name: CI/CD Pipeline

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  lint:
    name: Lint & Code Style
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up [LanguageName]
        uses: actions/setup-[LanguageName]@v4
        with:
          [LanguageName]-version: '[Version]'
          cache: '[PackageManager]' # e.g. npm, pip, go-modules

      - name: Install Dependencies
        run: [InstallDependenciesCommand]

      - name: Run Linter
        run: [LintCommand]

  test:
    name: Unit & Integration Tests
    runs-on: ubuntu-latest
    needs: lint
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up [LanguageName]
        uses: actions/setup-[LanguageName]@v4
        with:
          [LanguageName]-version: '[Version]'
          cache: '[PackageManager]'

      - name: Install Dependencies
        run: [InstallDependenciesCommand]

      - name: Run Tests
        run: [TestCommand]

  build-and-push:
    name: Build & Push Docker Image
    runs-on: ubuntu-latest
    needs: test
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v2

      - name: Log in to Registry
        uses: docker/login-action@v2
        with:
          registry: ${{ secrets.REGISTRY_URL }}
          username: ${{ secrets.REGISTRY_USERNAME }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

      - name: Build & Push Image
        uses: docker/build-push-action@v4
        with:
          context: .
          push: true
          tags: ${{ secrets.REGISTRY_URL }}/[AppName]:latest,${{ secrets.REGISTRY_URL }}/[AppName]:${{ github.sha }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
