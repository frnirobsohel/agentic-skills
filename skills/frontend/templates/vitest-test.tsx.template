import React from "react";
import { render, screen } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { describe, it, expect, vi } from "vitest";
import { ActionButton } from "./ActionButton";

describe("ActionButton Component", () => {
  it("renders with correct label and default attributes", () => {
    render(<ActionButton>Click Me</ActionButton>);
    const btn = screen.getByRole("button", { name: /click me/i });
    expect(btn).toBeInTheDocument();
    expect(btn).not.toBeDisabled();
    expect(btn).toHaveAttribute("type", "button");
  });

  it("handles user click events appropriately", async () => {
    const user = userEvent.setup();
    const handleClick = vi.fn();
    render(<ActionButton onClick={handleClick}>Submit</ActionButton>);

    const btn = screen.getByRole("button", { name: /submit/i });
    await user.click(btn);

    expect(handleClick).toHaveBeenCalledTimes(1);
  });

  it("disables button and sets aria-busy when isLoading is true", () => {
    render(<ActionButton isLoading>Saving</ActionButton>);
    const btn = screen.getByRole("button", { name: /saving/i });

    expect(btn).toBeDisabled();
    expect(btn).toHaveAttribute("aria-busy", "true");
  });
});
