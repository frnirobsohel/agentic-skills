"use client";

import React, { type ButtonHTMLAttributes } from "react";

interface ActionButtonProps extends ButtonHTMLAttributes<HTMLButtonElement> {
  /** Visual variant styling */
  variant?: "primary" | "secondary" | "outline" | "danger";
  /** Size modifier */
  size?: "sm" | "md" | "lg";
  /** Shows spinner and disables interaction when true */
  isLoading?: boolean;
  /** Optional icon rendered to the left of the label */
  icon?: React.ReactNode;
}

/**
 * Production-Grade Accessible Button Component
 * Complies with WCAG touch target standards (min 44px) and keyboard focus rings.
 */
export function ActionButton({
  variant = "primary",
  size = "md",
  isLoading = false,
  icon,
  children,
  className = "",
  disabled,
  ...props
}: ActionButtonProps) {
  const baseStyles =
    "inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-slate-950 disabled:opacity-50 disabled:pointer-events-none select-none";

  const variants: Record<string, string> = {
    primary: "bg-indigo-600 text-white hover:bg-indigo-500 shadow-md shadow-indigo-600/20 active:scale-[0.98]",
    secondary: "bg-slate-800 text-slate-100 hover:bg-slate-700 border border-slate-700",
    outline: "border border-slate-700 text-slate-300 hover:bg-slate-800/50 hover:text-white",
    danger: "bg-rose-600 text-white hover:bg-rose-500 shadow-md shadow-rose-600/20 active:scale-[0.98]",
  };

  const sizes: Record<string, string> = {
    sm: "h-9 px-3 text-xs min-h-[44px]", // Ensures touch accessibility
    md: "h-11 px-4 text-sm min-h-[44px]",
    lg: "h-12 px-6 text-base min-h-[48px]",
  };

  const variantClass = variants[variant] ?? variants.primary;
  const sizeClass = sizes[size] ?? sizes.md;

  return (
    <button
      type="button"
      className={`${baseStyles} ${variantClass} ${sizeClass} ${className}`.trim()}
      disabled={disabled || isLoading}
      aria-busy={isLoading}
      {...props}
    >
      {isLoading && (
        <svg
          className="mr-2 h-4 w-4 animate-spin text-current"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4" />
          <path
            className="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          />
        </svg>
      )}
      {!isLoading && icon && <span className="mr-2 inline-flex items-center" aria-hidden="true">{icon}</span>}
      <span>{children}</span>
    </button>
  );
}
