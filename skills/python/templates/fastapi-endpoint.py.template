from typing import Annotated
from fastapi import APIRouter, Depends, HTTPException, status
from pydantic import BaseModel, EmailStr
from sqlalchemy.orm import Session

router = APIRouter(prefix="/v1/users", tags=["Users"])

# Schemas
class UserBase(BaseModel):
    email: EmailStr

class UserCreate(UserBase):
    password: str

class UserResponse(UserBase):
    id: int
    is_active: bool

    class Config:
        orm_mode = True

# Mock DB Session Dependency
def get_db():
    db = "database_session_placeholder"
    try:
        yield db
    finally:
        pass

@router.post("/", response_model=UserResponse, status_code=status.HTTP_201_CREATED)
def create_user(
    user_data: UserCreate, 
    db: Annotated[Session, Depends(get_db)]
):
    # Enforce validation and check existing user
    user_exists = False  # db.query(User).filter(User.email == user_data.email).first()
    if user_exists:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Email already registered"
        )
    
    # Password hashing and creation logic should go here
    new_user = {
        "id": 1,
        "email": user_data.email,
        "is_active": True
    }
    return new_user
